# --- LLM Backend ---
LLM_BACKEND=azure

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://oai-gopoc-prod-northcentralus-001.openai.azure.com
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_REASONING=o4-mini-graphRAG-Miguel
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4o-Miguel-Graphrag
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large

# --- Ollama ---
OLLAMA_BASE_URL=http://192.168.100.250:11434
OLLAMA_MODEL=llama3.3:70b

# --- PostgreSQL ---
POSTGRES_HOST=bmi-postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-password>

# --- App ---
LOG_LEVEL=INFO
WATCHFILES_FORCE_POLLING=true
